# ===========================================
# SmartCV IA - Variables de Entorno
# ===========================================
# Copia este archivo como .env en la raíz del proyecto

# Google Gemini API (obligatorio para funciones de IA)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Backend (usado por docker-compose)
JWT_SECRET=SmFydFNlY3JldEtleUZvclNtYXJ0Q1ZJQVBwbGljYXRpb24yMDI2RGV2
JWT_EXPIRATION=86400000
GEMINI_MODEL=gemini-2.5-flash

# Base de datos (desarrollo local sin Docker)
DATABASE_URL=jdbc:postgresql://localhost:5432/smartcv
DB_USERNAME=smartcv
DB_PASSWORD=smartcv123

# CORS (agregar URL de Vercel en producción)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080/api

# Datos demo (true en desarrollo/Docker, false en producción)
SEED_DATA=true

# Usuarios demo (creados automáticamente si SEED_DATA=true):
#   demo@smartcv.com / demo123  (USER - CV completo)
#   admin@smartcv.com / admin123 (ADMIN)

# ===========================================
# Producción - Render (Backend)
# ===========================================
# DATABASE_URL=jdbc:postgresql://user:pass@host/db?sslmode=require
# PORT=8080
# CORS_ALLOWED_ORIGINS=https://tu-app.vercel.app

# ===========================================
# Producción - Neon (PostgreSQL)
# ===========================================
# Usar la connection string de Neon con prefijo jdbc:
# jdbc:postgresql://ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ===========================================
# Producción - Vercel (Frontend)
# ===========================================
# VITE_API_BASE_URL=https://tu-backend.onrender.com/api
